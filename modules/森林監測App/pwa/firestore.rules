rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() { return request.auth != null; }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    // 過渡期同時支援 systemRole（v1.5）與 globalRole（v1.0），最終只留 systemRole
    function isSystemAdmin() {
      let d = userDoc();
      return d.systemRole == 'admin' || d.globalRole == 'admin';
    }

    function projectDoc(pid) {
      return get(/databases/$(database)/documents/projects/$(pid)).data;
    }
    function userRole(pid)        { return projectDoc(pid).members[request.auth.uid]; }
    function isPi(pid)            { return userRole(pid) == 'pi'; }
    function isSurveyor(pid)      { return userRole(pid) == 'surveyor'; }
    function isReviewer(pid)      { return userRole(pid) == 'reviewer'; }
    function isMember(pid)        { return userRole(pid) != null; }
    // v2.7.8：canCollect 加 isSystemAdmin（與 canRead 風格一致）
    //   修前：plot 子集合 create（trees/regeneration/understory/...）只允許 isPi || isSurveyor
    //   修後：admin god view 不需自己是 PI 也能透過 import wizard 寫入立木與其他子集合
    function canCollect(pid)      { return isPi(pid) || isSurveyor(pid) || isSystemAdmin(); }
    function canRead(pid)         { return isMember(pid) || isSystemAdmin(); }

    function isLocked(pid)        { return projectDoc(pid).locked == true; }
    function isOwner()            { return resource.data.createdBy == request.auth.uid; }
    function willOwn()            { return request.resource.data.createdBy == request.auth.uid; }

    // v2.7.15：樣區幾何 schema 升級的欄位驗證（plot create/update 用）
    //   寬鬆策略：欄位若不存在或為 null → 跳過驗證（既有資料無欄位 = 待補登）
    //   只在欄位實際存在時檢 enum / range；不檢 areaHorizontal_m2（client 端算，db 端不再演算驗證避免 floating point）
    function validPlotGeomFields(d) {
      return (!('shape' in d) || d.shape in ['circle', 'square', 'rectangle'])
          && (!('dimensionType' in d) || d.dimensionType == null || d.dimensionType in ['slope_distance', 'horizontal'])
          && (!('slopeSource' in d) || d.slopeSource == null || d.slopeSource in ['field', 'dem', 'dem_field_avg'])
          && (!('slopeDegrees' in d) || d.slopeDegrees == null || (d.slopeDegrees is number && d.slopeDegrees >= 0 && d.slopeDegrees <= 90))
          && (!('slopeAspect' in d) || d.slopeAspect == null || (d.slopeAspect is number && d.slopeAspect >= 0 && d.slopeAspect <= 360));
    }
    // 同樣的 enum 也套到 methodology（project doc 內）
    function validMethodologyGeomFields(d) {
      let m = d.get('methodology', {});
      return (!('plotShape' in m) || m.plotShape in ['circle', 'square', 'rectangle'])
          && (!('dimensionType' in m) || m.dimensionType in ['slope_distance', 'horizontal']);
    }

    // ===== Users =====
    match /users/{uid} {
      allow read:  if isSignedIn() && (request.auth.uid == uid || isSystemAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ===== Projects =====
    match /projects/{projectId} {
      // admin 可讀全部；成員可讀自己的（用 memberUids 陣列以對齊 client list query）
      // 注意：rule 必須用 resource.data 直接欄位，與 query 的 array-contains 對齊，否則 Firestore 拒絕整批 list query
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.get('memberUids', []) ||
        isSystemAdmin()
      );

      // 只有 system admin 可建專案；建時必須含自己且 pi 必須在 members 中
      // v2.7.15：methodology 含新欄位（plotShape='rectangle' / dimensionType）→ enum 驗證
      allow create: if isSignedIn() && isSystemAdmin() &&
        request.resource.data.memberUids is list &&
        request.auth.uid in request.resource.data.memberUids &&
        request.resource.data.members[request.resource.data.pi] == 'pi' &&
        validMethodologyGeomFields(request.resource.data);

      // v1.7.1.2：PI 或 system admin 可改（admin god view，不需自己是 PI 也能管理 members）
      // v2.7：reviewer 限定一條路 — review→verified 完成審查
      //   條件：cur status='review'、new status='verified'、僅改狀態機相關欄位（不可動 methodology/members 等）
      // v2.7.15：methodology enum 驗證套到所有 update path（reviewer 沒改 methodology → 既有值仍合法 → pass）
      allow update: if isSignedIn() && validMethodologyGeomFields(request.resource.data) && (
        isPi(projectId) || isSystemAdmin() ||
        (isReviewer(projectId)
          && resource.data.get('status', 'active') == 'review'
          && request.resource.data.status == 'verified'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'statusChangedAt', 'statusChangedBy',
              'locked', 'lockedAt', 'lockedBy', 'autoLockReason',
              'verifiedAt', 'verifiedBy'
            ])
        )
      );

      // admin 可刪空殼專案（v1.5 簡化：不檢查 plotCount）
      allow delete: if isSignedIn() && isSystemAdmin();

      // ===== Plots =====
      match /plots/{plotId} {
        allow read: if isSignedIn() && canRead(projectId);

        // create：建立時不強制 qaStatus（client 端會自動帶 'pending'）
        // v2.7.8：拿掉 || isSystemAdmin() — canCollect 已 include
        // v2.7.15：plot 幾何欄位 enum 驗證（shape / dimensionType / slopeSource / slopeDegrees / slopeAspect）
        allow create: if isSignedIn() && canCollect(projectId) && willOwn() && !isLocked(projectId)
                      && validPlotGeomFields(request.resource.data);

        // v1.7.1.3：systemAdmin god view，跨任何專案角色限制
        // v2.7.15：同 create 套 plot 幾何欄位 enum 驗證
        allow update: if isSignedIn() && !isLocked(projectId)
                      && validPlotGeomFields(request.resource.data) && (
          isSystemAdmin() ||
          isPi(projectId) ||
          (isSurveyor(projectId) && (isOwner() || resource.data.get('assignedTo', null) == request.auth.uid))
        );

        allow delete: if isSignedIn() && (
          isSystemAdmin() ||
          isPi(projectId) ||
          (isSurveyor(projectId) && isOwner())
        );

        // ===== Trees / Regeneration / Understory / SoilCons =====
        // v2.0：加 understory（地被植物）+ soilCons（水土保持）兩子集合，沿用同樣 QA 流程
        match /{subColl}/{docId} {
          allow read: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] && canRead(projectId);

          allow create: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] &&
            canCollect(projectId) && willOwn() && !isLocked(projectId);

          // v1.7.1.3：systemAdmin god view
          allow update: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] && !isLocked(projectId) && (
            isSystemAdmin() ||
            isPi(projectId) ||
            (isSurveyor(projectId) && isOwner())
          );

          allow delete: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] && (
            isSystemAdmin() ||
            isPi(projectId) ||
            (isSurveyor(projectId) && isOwner())
          );
        }
      }
    }

    // ===== Lookups =====（保留，目前未使用 — 原 path /lookups/{collection}/{docId} 是 3-segment subcollection 寫法不會 match 任何 doc）
    match /lookups/{collection}/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ===== Species 字典 =====
    // v2.7.4：top-level `species/{docId}` — 平台共享樹種字典
    //   首批用途：import wizard 把未知樹種 seed 進來為 verified=false，PI/admin 後續逐筆審核補學名/保育等級
    //   read：所有登入使用者可查（任一專案匯入時都要比對）
    //   write：僅 systemAdmin（共享字典守門員）
    match /species/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSystemAdmin();

      // v2.7.11 🆔e：變更歷史 sub-collection — admin 編輯/批次/CSV 匯入時併寫一筆
      //   read：所有登入者可查（追溯誰改了什麼）
      //   create：僅 systemAdmin（與主 doc write 一致）
      //   update / delete：永遠拒絕（歷史不可修改，append-only audit log）
      match /history/{histId} {
        allow read:   if isSignedIn();
        allow create: if isSystemAdmin();
        allow update, delete: if false;
      }
    }
  }
}
