rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====
    function isSignedIn() { return request.auth != null; }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    // 過渡期同時支援 systemRole（v1.5）與 globalRole（v1.0），最終只留 systemRole
    function isSystemAdmin() {
      let d = userDoc();
      return d.systemRole == 'admin' || d.globalRole == 'admin';
    }

    function projectDoc(pid) {
      return get(/databases/$(database)/documents/projects/$(pid)).data;
    }
    function userRole(pid)        { return projectDoc(pid).members[request.auth.uid]; }
    function isPi(pid)            { return userRole(pid) == 'pi'; }
    function isSurveyor(pid)      { return userRole(pid) == 'surveyor'; }
    function isReviewer(pid)      { return userRole(pid) == 'reviewer'; }
    // v2.11.33：林業保育署臺中分署採收審核者（外部主管機關角色，比照 reviewer 受限寫法）
    function isHarvestAuthority(pid) { return userRole(pid) == 'harvest_authority'; }
    function isMember(pid)        { return userRole(pid) != null; }
    // v2.11.34：收穫量登錄 — 取父許可單 doc（判斷狀態與許可單擁有者）
    function harvestPermitDoc(pid, pmid) {
      return get(/databases/$(database)/documents/projects/$(pid)/harvestPermits/$(pmid)).data;
    }
    // v2.7.8：canCollect 加 isSystemAdmin（與 canRead 風格一致）
    //   修前：plot 子集合 create（trees/regeneration/understory/...）只允許 isPi || isSurveyor
    //   修後：admin god view 不需自己是 PI 也能透過 import wizard 寫入立木與其他子集合
    function canCollect(pid)      { return isPi(pid) || isSurveyor(pid) || isSystemAdmin(); }
    function canRead(pid)         { return isMember(pid) || isSystemAdmin(); }

    function isLocked(pid)        { return projectDoc(pid).locked == true; }
    function isOwner()            { return resource.data.createdBy == request.auth.uid; }
    function willOwn()            { return request.resource.data.createdBy == request.auth.uid; }

    // v2.7.15：樣區幾何 schema 升級的欄位驗證（plot create/update 用）
    // v2.8.0：plotShape enum 加 'irregular'（不規則多邊形）
    //   寬鬆策略：欄位若不存在或為 null → 跳過驗證（既有資料無欄位 = 待補登）
    //   只在欄位實際存在時檢 enum / range；不檢 areaHorizontal_m2（client 端算，db 端不再演算驗證避免 floating point）
    function validPlotGeomFields(d) {
      return (!('shape' in d) || d.shape in ['circle', 'square', 'rectangle', 'irregular'])
          && (!('dimensionType' in d) || d.dimensionType == null || d.dimensionType in ['slope_distance', 'horizontal'])
          && (!('slopeSource' in d) || d.slopeSource == null || d.slopeSource in ['field', 'dem', 'dem_field_avg'])
          && (!('slopeDegrees' in d) || d.slopeDegrees == null || (d.slopeDegrees is number && d.slopeDegrees >= 0 && d.slopeDegrees <= 90))
          && (!('slopeAspect' in d) || d.slopeAspect == null || (d.slopeAspect is number && d.slopeAspect >= 0 && d.slopeAspect <= 360));
    }
    // I-2（v2.11.40）：複查期別欄位驗證（寬鬆 — 欄位不存在則跳過，向後相容既有 plot）
    //   periods 為物件陣列（繞過 Firestore array-of-array 限制）；currentPeriod 為期序數字或 null
    //   深層內容（每期 seq/label/openedAt…）不在 rules 檢，留 client 端保證
    function validPlotPeriodFields(d) {
      return (!('periods' in d) || d.periods is list)
          && (!('currentPeriod' in d) || d.currentPeriod == null || d.currentPeriod is number);
    }
    // 同樣的 enum 也套到 methodology（project doc 內）
    function validMethodologyGeomFields(d) {
      let m = d.get('methodology', {});
      return (!('plotShape' in m) || m.plotShape in ['circle', 'square', 'rectangle', 'irregular'])
          && (!('dimensionType' in m) || m.dimensionType in ['slope_distance', 'horizontal']);
    }

    // ===== Users =====
    // v2.11.27：read 對所有登入者開放（避免 PI 無法 query /users by email 加成員）
    //   修前：只允許 uid==auth.uid || isSystemAdmin → PI 加成員 query 整批被擋 → client catch
    //     在誤導為「目前的角色無法變更成員」；同時 PI 看成員清單名字也 silently fail
    //   修後：所有登入者可 read /users（email / displayName / systemRole）
    //     ForestMRV 為內部教學工具、user 都是同單位老師學生、email 互寄本就公開 → 隱私風險低
    //   write 維持只能改自己
    match /users/{uid} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ===== Projects =====
    match /projects/{projectId} {
      // admin 可讀全部；成員可讀自己的（用 memberUids 陣列以對齊 client list query）
      // 注意：rule 必須用 resource.data 直接欄位，與 query 的 array-contains 對齊，否則 Firestore 拒絕整批 list query
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.get('memberUids', []) ||
        isSystemAdmin()
      );

      // 只有 system admin 可建專案；建時必須含自己且 pi 必須在 members 中
      // v2.7.15：methodology 含新欄位（plotShape='rectangle' / dimensionType）→ enum 驗證
      allow create: if isSignedIn() && isSystemAdmin() &&
        request.resource.data.memberUids is list &&
        request.auth.uid in request.resource.data.memberUids &&
        request.resource.data.members[request.resource.data.pi] == 'pi' &&
        validMethodologyGeomFields(request.resource.data);

      // v1.7.1.2：PI 或 system admin 可改（admin god view，不需自己是 PI 也能管理 members）
      // v2.7：reviewer 限定一條路 — review→verified 完成審查
      //   條件：cur status='review'、new status='verified'、僅改狀態機相關欄位（不可動 methodology/members 等）
      // v2.7.15：methodology enum 驗證套到所有 update path（reviewer 沒改 methodology → 既有值仍合法 → pass）
      // v2.7.17：reviewer 在 status=review 時可改 qaqcConfig（抽樣比例 / 閾值；專業判斷）
      allow update: if isSignedIn() && validMethodologyGeomFields(request.resource.data) && (
        isPi(projectId) || isSystemAdmin() ||
        (isReviewer(projectId) && (
          (resource.data.get('status', 'active') == 'review'
            && request.resource.data.status == 'verified'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status', 'statusChangedAt', 'statusChangedBy',
                'locked', 'lockedAt', 'lockedBy', 'autoLockReason',
                'verifiedAt', 'verifiedBy',
                'qaqcSummary'
              ])
          ) ||
          (resource.data.get('status', 'active') == 'review'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['qaqcConfig'])
          )
        ))
      );

      // admin 可刪空殼專案（v1.5 簡化：不檢查 plotCount）
      allow delete: if isSignedIn() && isSystemAdmin();

      // ===== Plots =====
      match /plots/{plotId} {
        allow read: if isSignedIn() && canRead(projectId);

        // create：建立時不強制 qaStatus（client 端會自動帶 'pending'）
        // v2.7.8：拿掉 || isSystemAdmin() — canCollect 已 include
        // v2.7.15：plot 幾何欄位 enum 驗證（shape / dimensionType / slopeSource / slopeDegrees / slopeAspect）
        allow create: if isSignedIn() && canCollect(projectId) && willOwn() && !isLocked(projectId)
                      && validPlotGeomFields(request.resource.data)
                      && validPlotPeriodFields(request.resource.data);

        // v1.7.1.3：systemAdmin god view，跨任何專案角色限制
        // v2.7.15：同 create 套 plot 幾何欄位 enum 驗證
        // v2.7.17：reviewer 可寫 qaqc 子結構（與既有 PI/surveyor 寫權限平行）
        //   - 既有路徑（PI/admin/surveyor）：須 !isLocked（防止鎖定後 surveyor 仍能改）
        //   - reviewer 路徑：允許 isLocked 狀態（鎖定是擋 surveyor 的，不擋查證）；diff 只能是 qaqc + updatedAt
        // I-2（v2.11.40）：複查期別後門 — 第三條 OR。動機：複查本質發生於第一期全 verified
        //   + 專案 auto-Lock 之後，現行 PI/surveyor/admin 路徑要求 !isLocked → 鎖定後無法開新一期
        //   （即記憶 project_resurvey_workflow_gap 核心缺口 iii「verified 後無回頭路」）。
        //   比照 reviewer-qaqc 後門 pattern：不檢 isLocked，但 diff 僅限 periods/currentPeriod/
        //   updatedAt，授權僅 admin/pi（surveyor 不得在鎖定後開期 — 期別是管理決策）。
        allow update: if isSignedIn()
                      && validPlotGeomFields(request.resource.data)
                      && validPlotPeriodFields(request.resource.data) && (
          (!isLocked(projectId) && (
            isSystemAdmin() ||
            isPi(projectId) ||
            (isSurveyor(projectId) && (isOwner() || resource.data.get('assignedTo', null) == request.auth.uid))
          )) ||
          (isReviewer(projectId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['qaqc', 'updatedAt'])) ||
          ((isSystemAdmin() || isPi(projectId))
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['periods', 'currentPeriod', 'updatedAt']))
        );

        allow delete: if isSignedIn() && (
          isSystemAdmin() ||
          isPi(projectId) ||
          (isSurveyor(projectId) && isOwner())
        );

        // ===== Trees / Regeneration / Understory / SoilCons =====
        // v2.0：加 understory（地被植物）+ soilCons（水土保持）兩子集合，沿用同樣 QA 流程
        match /{subColl}/{docId} {
          allow read: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] && canRead(projectId);

          allow create: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] &&
            canCollect(projectId) && willOwn() && !isLocked(projectId);

          // v1.7.1.3：systemAdmin god view
          // v2.8.1：reviewer 可寫 tree.qaqc（hasOnly + 限 trees subcollection；允許 isLocked 狀態以利查證）
          allow update: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] && (
            (!isLocked(projectId) && (
              isSystemAdmin() ||
              isPi(projectId) ||
              (isSurveyor(projectId) && isOwner())
            )) ||
            (isReviewer(projectId) && subColl == 'trees'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['qaqc', 'updatedAt']))
          );

          allow delete: if isSignedIn() && subColl in ['trees', 'regeneration', 'understory', 'soilCons', 'wildlife', 'harvest'] && (
            isSystemAdmin() ||
            isPi(projectId) ||
            (isSurveyor(projectId) && isOwner())
          );
        }

        // ===== I-1（v2.11.41）：立木逐期歷史測值子集合（永久樣區複查地基）=====
        // 通用 match /{subColl}/{docId} 只比對單層 → 深層 trees/{id}/measurements/{periodId}
        //   預設 deny，必須顯式 match。語意：append-only 歷史，client 不可刪（審計完整性）。
        //   - read：成員可讀（同 trees）
        //   - create：canCollect + willOwn（snapshot.createdBy==auth）+ !isLocked（同 trees 採集）
        //   - update：未鎖定時 admin/pi/或本人 surveyor（修正「當期」measurement；關閉期凍結由 client 控）
        //   - delete：一律 false（歷史不可從 client 銷毀；如需回收用 owner-token backfill --undo）
        // I-2b（v2.11.42，已解）：第一期 verified→專案 auto-Lock 後第二期採集本被 !isLocked 擋；
        //   forms.openNewPeriod 改為「開新一期＝重啟採集」：PI/admin 同步把專案降回 status=active
        //   / locked=false（project update 對 PI/admin 本無 isLocked 閘），並先存 periodVerifications
        //   期別查證簿保留「第 N-1 期曾查證」。專案解鎖後本 create 規則 !isLocked 即放行第二期。
        //   第 N-1 期測值已凍結（下方 delete:false）→ 重啟採集 MRV 安全。
        match /trees/{treeId}/measurements/{periodId} {
          allow read:   if isSignedIn() && canRead(projectId);
          allow create: if isSignedIn() && canCollect(projectId) && willOwn() && !isLocked(projectId);
          allow update: if isSignedIn() && !isLocked(projectId) && (
            isSystemAdmin() || isPi(projectId) || (isSurveyor(projectId) && isOwner())
          );
          allow delete: if false;
        }
      }

      // ===== 收穫採取許可（v2.11.33 / 擴充 v2.11.34）=====
      // 土肉桂葉片採收行政流程電子化：林農申請 → 林保署核准（生許可文號）→ 收穫量登錄 → 結案
      //   read：專案成員 + admin（林農看自己 / 分署看全部，UI 端再分流）
      //   create：canCollect（pi/surveyor/admin = 林農端）+ willOwn + 初始 status draft|submitted
      //   update (A) 申請人/PI/admin：僅 draft|revision 時可改，目標 draft|submitted（補正再送）
      //   update (B) harvest_authority（分署）：僅 submitted|under_review、只能改狀態+審核欄位+許可文號
      //              （比照 reviewer QAQC 的 affectedKeys().hasOnly 受限寫法，不可動申請內容）
      //   update (C) v2.11.34 申請人/PI/admin 採收期：approved|harvesting → harvesting|completed
      //              只能改 status / 採收期時戳 / totalLogged_kg（不可回頭改申請或核准內容）
      //   不受 isLocked 連動：許可流程是獨立行政程序，與研究資料 Lock 無關
      match /harvestPermits/{permitId} {
        allow read: if isSignedIn() && canRead(projectId);

        allow create: if isSignedIn() && canCollect(projectId) && willOwn()
                      && request.resource.data.status in ['draft', 'submitted'];

        allow update: if isSignedIn() && (
          ((isOwner() || isPi(projectId) || isSystemAdmin())
            && resource.data.get('status', 'draft') in ['draft', 'revision']
            && request.resource.data.status in ['draft', 'submitted'])
          ||
          (isHarvestAuthority(projectId)
            && resource.data.get('status', 'draft') in ['submitted', 'under_review']
            && request.resource.data.status in ['under_review', 'approved', 'rejected', 'revision']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status', 'reviewedBy', 'reviewedAt', 'reviewComment',
                'approvedAmount_kg', 'validFrom', 'validUntil',
                'permitNo', 'permitSeq', 'updatedAt'
              ]))
          ||
          ((isOwner() || isPi(projectId) || isSystemAdmin())
            && resource.data.get('status', 'draft') in ['approved', 'harvesting']
            && request.resource.data.status in ['harvesting', 'completed']
            // v2.11.39 (G1)：結案（→completed）伺服器層硬擋零回報 — 必須已有回報累計
            //   totalLogged_kg > 0。連帶堵掉「approved 直接跳 completed 跳過 harvesting」
            //   （首筆回報才會 approved→harvesting，故 totalLogged_kg>0 必經回報）。
            && (request.resource.data.status != 'completed'
                || resource.data.get('totalLogged_kg', 0) > 0)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status', 'harvestingStartedAt', 'completedAt', 'totalLogged_kg', 'updatedAt'
              ]))
        );

        allow delete: if isSignedIn() && (
          isSystemAdmin() ||
          isPi(projectId) ||
          (isOwner() && resource.data.get('status', 'draft') == 'draft')
        );

        // ===== 收穫量登錄（v2.11.34）=====
        //   read：專案成員 + admin（分署查核需可讀）
        //   write：許可單擁有者 / PI / admin，且僅在父許可單 approved|harvesting 時
        //          （harvest_authority 不寫 logs — 分署只審核，不代登錄）
        match /logs/{logId} {
          allow read: if isSignedIn() && canRead(projectId);

          allow create: if isSignedIn() && canCollect(projectId) && willOwn()
            && harvestPermitDoc(projectId, permitId).get('status', 'draft') in ['approved', 'harvesting']
            && (harvestPermitDoc(projectId, permitId).createdBy == request.auth.uid
                || isPi(projectId) || isSystemAdmin());

          allow update, delete: if isSignedIn()
            && harvestPermitDoc(projectId, permitId).get('status', 'draft') in ['approved', 'harvesting']
            && (isOwner() || isPi(projectId) || isSystemAdmin());
        }
      }

      // ===== 許可文號流水號計數器（v2.11.34）=====
      // 法定許可文號不可重號 → 用 Firestore transaction 原子遞增（解 treeCode 非原子同類問題）
      //   read：專案成員 + admin　write：核准者（分署）/ PI / admin（核准當下交易遞增）
      match /counters/{counterId} {
        allow read:  if isSignedIn() && canRead(projectId);
        allow write: if isSignedIn() && (
          isHarvestAuthority(projectId) || isPi(projectId) || isSystemAdmin()
        );
      }
    }

    // ===== Lookups =====（保留，目前未使用 — 原 path /lookups/{collection}/{docId} 是 3-segment subcollection 寫法不會 match 任何 doc）
    match /lookups/{collection}/{docId} {
      allow read:  if isSignedIn();
      allow write: if false;
    }

    // ===== Species 字典 =====
    // v2.7.4：top-level `species/{docId}` — 平台共享樹種字典
    //   首批用途：import wizard 把未知樹種 seed 進來為 verified=false，PI/admin 後續逐筆審核補學名/保育等級
    //   read：所有登入使用者可查（任一專案匯入時都要比對）
    //   write：僅 systemAdmin（共享字典守門員）
    //
    // v2.11.17（F1）：放寬 create — 任何登入者可在嚴格 shape 下建立 verified=false 候選
    //   （AI 辨識字典外 + iNat/LLM resolved 補洞）；update / delete 仍 admin only（防覆寫已驗證資料）。
    //   server-side shape 守門：verified=false + addedFrom in {ai-identify-iNat, ai-identify-LLM}
    //                         + addedBy=自己 uid + zh/sci 為非空字串
    //   client-side 額外限制：只有 admin / PI 會觸發此寫入（surveyor 不寫，避免低品質候選氾濫）
    match /species/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && (
        isSystemAdmin() ||
        (
          request.resource.data.verified == false &&
          request.resource.data.addedFrom in ['ai-identify-iNat', 'ai-identify-LLM'] &&
          request.resource.data.addedBy == request.auth.uid &&
          request.resource.data.zh is string && request.resource.data.zh.size() > 0 &&
          request.resource.data.sci is string && request.resource.data.sci.size() > 0
        )
      );
      allow update: if isSystemAdmin();
      allow delete: if isSystemAdmin();

      // v2.7.11 🆔e：變更歷史 sub-collection — admin 編輯/批次/CSV 匯入時併寫一筆
      //   read：所有登入者可查（追溯誰改了什麼）
      //   create：僅 systemAdmin（與主 doc write 一致）
      //   update / delete：永遠拒絕（歷史不可修改，append-only audit log）
      match /history/{histId} {
        allow read:   if isSignedIn();
        allow create: if isSystemAdmin();
        allow update, delete: if false;
      }
    }

    // ===== App Settings（v2.11.4）=====
    // 全域共用設定（如 AI 辨識的 PlantNet API key + CORS Proxy URL）
    //   read：所有登入者（執行 AI 辨識需讀取）
    //   write：僅 systemAdmin（避免 user 亂改全域 key）
    match /app_settings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isSystemAdmin();
    }
  }
}
