# Google Drive 系統檔
desktop.ini
*.tmp
~$*
Thumbs.db

# 敏感資料
.env
*.key
credentials.*

# Firebase 本地實際 config（即使列入也安全，但保持與 example 分離）
**/firebase-config.js
**/.firebaserc
**/firebase-debug.log

# Firebase Admin SDK 服務帳戶金鑰（極敏感！可繞過所有 Security Rules）
**/serviceAccountKey.json
**/*-firebase-adminsdk-*.json

# Firebase init 自動裝的 Agent Skills（給 AI agent 的參考文件，會自動更新，不該進 repo）
**/.agents/
**/skills-lock.json

# Claude Code 本地設定（含 permissions、可能記錄 token，絕不上雲）
.claude/

# Node.js
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
.venv/
venv/

# GIS 暫存
*.tif.aux.xml
*.lock
.qgz~
*.gpkg-shm
*.gpkg-wal

# 大型資料（視情況解開註解）
# data/raw/
# *.las
# *.laz

# 編輯器
.vscode/
.idea/
*.swp
.DS_Store
